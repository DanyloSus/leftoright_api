# Production environment variables template.
# Copy to /home/ubuntu/app/.env.prod on EC2 and fill in real values.

# --- Database (RDS) ---
DB_USER=leftoright
DB_PASSWORD=<rds-password>
DB_HOST=<rds-endpoint>.rds.amazonaws.com
DB_PORT=5432
DB_NAME=leftoright

# --- Redis (ElastiCache) ---
REDIS_HOST=<elasticache-endpoint>.cache.amazonaws.com
REDIS_PORT=6379

# --- JWT ---
JWT_SECRET_KEY=<generate-a-strong-secret>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=108000

# --- CORS ---
CORS_ALLOW_ORIGINS=["https://yourdomain.com"]
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
